<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Website</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #0f172a;
      color: white;
      line-height: 1.6;
    }

    header {
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 20px;
      background: linear-gradient(to bottom right, #1e293b, #0f172a);
    }

    header h1 {
      font-size: 4rem;
      margin-bottom: 10px;
    }

    header p {
      font-size: 1.2rem;
      max-width: 600px;
      opacity: 0.8;
    }

    .btn {
      margin-top: 25px;
      display: inline-block;
      padding: 12px 24px;
      background: #38bdf8;
      color: black;
      text-decoration: none;
      border-radius: 10px;
      font-weight: bold;
      transition: 0.3s;
    }

    .btn:hover {
      background: #0ea5e9;
      transform: scale(1.05);
    }

    section {
      padding: 80px 20px;
      max-width: 1000px;
      margin: auto;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }

    .card {
      background: #1e293b;
      padding: 25px;
      border-radius: 15px;
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
      background: #334155;
    }

    footer {
      text-align: center;
      padding: 20px;
      background: #020617;
      opacity: 0.8;
    }
  </style>
</head>
<body>

  <header>
    <h1>Welcome to My Website</h1>
    <p>
      This website was created with HTML and CSS and can be hosted for free using GitHub Pages.
    </p>
    <a href="#projects" class="btn">View Projects</a>
  </header>

  <section id="projects">
    <h2>My Projects</h2>
    <div class="cards">
      <div class="card">
        <h3>Project One</h3>
        <p>A simple project description goes here.</p>
      </div>

      <div class="card">
        <h3>Project Two</h3>
        <p>You can replace this text with your own ideas.</p>
      </div>

      <div class="card">
        <h3>Project Three</h3>
        <p>Add links, images, or anything you want.</p>
      </div>
    </div>
  </section>

  <section>
    <h2>About Me</h2>
    <p>
      Write something about yourself here. You can talk about your hobbies,
      skills, school, business, or social media.
    </p>
  </section>

  <footer>
    <p>© 2026 My Website | Made with GitHub Pages</p>
  </footer>

</body>
</html>

